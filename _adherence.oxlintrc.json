{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--band",
      "--bg",
      "--font",
      "--green",
      "--green-dk",
      "--ink",
      "--line",
      "--maxw",
      "--muted",
      "--orange",
      "--orange-dk",
      "--r",
      "--r-lg",
      "--shadow",
      "--shadow-sm",
      "--sky-1",
      "--sky-2",
      "--text",
      "--yellow",
      "--yellow-dk"
    ],
    "tokenKinds": {
      "--green": "color",
      "--green-dk": "color",
      "--orange": "color",
      "--orange-dk": "color",
      "--yellow": "color",
      "--yellow-dk": "color",
      "--ink": "color",
      "--text": "font",
      "--muted": "color",
      "--sky-1": "color",
      "--sky-2": "color",
      "--bg": "color",
      "--band": "color",
      "--line": "color",
      "--r": "spacing",
      "--r-lg": "spacing",
      "--shadow-sm": "shadow",
      "--shadow": "shadow",
      "--font": "font",
      "--maxw": "spacing"
    },
    "fontFamilies": []
  }
}